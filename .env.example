# Supabase Configuration
# Copy this file to .env.local and fill in your values from:
# https://supabase.com/dashboard -> Project Settings -> API

# Public app variables used by Vite on the website.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-key
VITE_SUPABASE_STORAGE_BUCKET=portfolio-images
VITE_ADMIN_EMAILS=joeydodd@gmail.com

# Local-only variables for Supabase Edge Functions and Stripe.
# These do not get exposed to the browser unless you add a VITE_/NEXT_PUBLIC_ prefix.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SITE_URL=https://your-site-url.com
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_replace_me
STRIPE_PRICE_ID=price_replace_me

# Optional aliases supported by the app:
# VITE_SUPABASE_ANON_KEY=your-supabase-publishable-key
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-key
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=portfolio-images
# NEXT_PUBLIC_ADMIN_EMAILS=joeydodd@gmail.com
