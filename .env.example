# Supabase Configuration
# Copy this file to .env.local and fill in your values from:
# https://supabase.com/dashboard -> Project Settings -> API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional backward-compatible alias if an older deploy already uses it.
# The app now accepts either value, but VITE_SUPABASE_ANON_KEY is preferred.
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key
